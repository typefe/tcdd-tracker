# TCDD Ticket Bot Configuration

# Route configuration (comma-separated CITY1-CITY2 format)
# Available routes: ISTANBUL-KONYA, ISTANBUL-ANKARA, ANKARA-ISTANBUL, ANKARA-KONYA, KONYA-ISTANBUL, KONYA-ANKARA
ROUTES=ISTANBUL-KONYA,ANKARA-ISTANBUL

# Date configuration (comma-separated DD-MM-YYYY format)
CHECK_DATES=21-03-2026,22-03-2026

# Seat class configuration (comma-separated class codes or# Available classes: EKONOMI, BUSINESS, YATAKLI, LOCA, DISABLED
# Special keywords: ANY (all except disabled), ALL (includes disabled)
# Default: EKONOMI
SEAT_CLASSES=ANY

# Seat class configuration (comma-separated class codes)
# Available classes: EKONOMI, BUSINESS, YATAKLI, LOCA, DISABLED
# Special keywords: ANY (all except disabled), ALL (includes disabled)
# Default: EKONOMI
SEAT_CLASSES=ANY

# Seat class configuration (comma-separated class codes or# Available classes: EKONOMI, BUSINESS, YATAKLI, LOCA, DISABLED
# Special keywords: ANY (all except disabled), ALL (includes disabled)
# Default: EKONOMI
SEAT_CLASSES=ANY

# Check interval in seconds (default: 300)
CHECK_INTERVAL=300

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Telegram bot configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# TCDD API authentication
USER_AUTHORIZATION=your_user_auth
AUTHORIZATION=your_auth